# .env          →  real secrets · in .gitignore · never on GitHub


# Application
APP_NAME=Syncflow
APP_VERSION=0.1.0
# When True your app runs in debug mode — 
# detailed error messages, extra logging. 
# You set this to False in production because you never want to expose detailed error information to real users. 
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
DATABASE_URL=postgresql+asyncpg://syncflow_user:syncflow_password@postgres:5432/syncflow_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000